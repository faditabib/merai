# --- Required ---
# Direct Postgres connection string (Supabase → Project Settings → Database).
# Use the session pooler URI on Railway (IPv4).
SUPABASE_DB_URL=postgresql://postgres:PASSWORD@db.YOUR-PROJECT.supabase.co:5432/postgres

# --- Supabase API (storage access: signed URLs for uploads) ---
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Providers (validated lazily by the handlers that use them) ---
# Speech-to-text (Phase 1)
ASSEMBLYAI_API_KEY=

# AI reasoning — Claude Haiku ONLY in runtime calls (margin decision)
ANTHROPIC_API_KEY=

# Export rendering (Phase 4.5 — server-side). Local ffmpeg is the default
# (the Docker image installs it; FFMPEG_PATH overrides the binary path).
# Setting VERYGOODFFMPEG_API_KEY switches to the managed provider.
VERYGOODFFMPEG_API_KEY=
# FFMPEG_PATH=ffmpeg
# RENDER_ENGINE=local|verygoodffmpeg (optional override)

# Audio enhancement (Phase 5)
DOLBY_APP_KEY=
DOLBY_APP_SECRET=

# Royalty-free SFX (Phase 5)
PIXABAY_API_KEY=
